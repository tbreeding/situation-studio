# Leadership content-reader environment. Install as mode 0600 at
# /home/admin/projects/leadership/shared/content.env. Start in `shadow`; use
# `database` only after the public-reader cutover is explicitly approved.
LEADERSHIP_CONTENT_MODE=shadow
LEADERSHIP_DATABASE_URL=postgresql://leadership_content_reader:replace-me@127.0.0.1:5432/situation_studio
LEADERSHIP_CONTENT_CACHE_ROOT=/home/admin/projects/leadership/shared/content-cache
LEADERSHIP_CONTENT_TARGET=leadership-production
LEADERSHIP_SHADOW_REPORT_PATH=/home/admin/projects/leadership/shared/shadow-report.json
LEADERSHIP_CONTENT_REFRESH_MS=5000
LEADERSHIP_SECURE_COOKIES=true
# Server-to-server callbacks use the private origin so they do not depend on a
# browser's outer-gate session. Studio API paths are outside the root probe.
STUDIO_CANDIDATE_EXCHANGE_URL=http://192.168.1.120:3015/api/candidates/exchange
LEADERSHIP_CANDIDATE_EXCHANGE_SECRET=replace-with-the-same-at-least-32-byte-web-secret
STUDIO_OBSERVATION_ORIGIN=http://192.168.1.120:3015
LEADERSHIP_ATTESTATION_SECRET=replace-with-the-same-at-least-32-byte-web-secret
LEADERSHIP_ATTESTATION_KEY_ID=leadership-hmac-v1
LEADERSHIP_OBSERVATION_TRIGGER_SECRET=replace-with-the-same-at-least-32-byte-publisher-secret
