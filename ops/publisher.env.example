# Separate trusted-publisher service environment. Keep mode 0600 outside releases.
DATABASE_URL=postgresql://situation_studio_publisher:replace-me@127.0.0.1:5432/situation_studio
PUBLISHER_RUNTIME_ENV=production
PUBLISHER_PROFILE=protected-beta
PUBLISHER_REMOTE_URL=git@github.com:tbreeding/leadership-field-guide.git
PUBLISHER_STATE_ROOT=/home/situation-studio-publisher/state
PUBLISHER_RELEASE_ROOT=/home/admin/projects/leadership
PUBLISHER_PREVIEW_LINK=/home/admin/projects/leadership-preview/current
PUBLISHER_LIVE_LINK=/home/admin/projects/leadership/current
PUBLISHER_POLL_MS=2000
PUBLISHER_RUN_ONCE=0
