# Separate AI-worker service environment. Keep mode 0600 outside releases.
DATABASE_URL=postgresql://situation_studio_ai:replace-me@127.0.0.1:5432/situation_studio
STUDIO_RUNTIME_ENV=production
PROVIDER_EXECUTION_MODE=api
OPENAI_API_KEY=replace-with-dedicated-openai-service-key
# Optional fallback. OpenAI/Codex remains first in MODEL_POLICY.
ANTHROPIC_API_KEY=replace-with-dedicated-anthropic-service-key
WORKER_POLL_MS=2000
WORKER_RUN_ONCE=0

# Validation-only alternative; rejected when STUDIO_RUNTIME_ENV=production:
# STUDIO_RUNTIME_ENV=validation
# PROVIDER_EXECUTION_MODE=cli
# CODEX_BIN=/absolute/path/to/pinned/codex
# CODEX_HOME=/absolute/path/to/isolated/codex-home
# CLAUDE_BIN=/absolute/path/to/pinned/claude
# CLAUDE_CODE_OAUTH_TOKEN=validation-only-token
