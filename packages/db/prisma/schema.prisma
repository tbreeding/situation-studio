generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum IdentityType {
  HUMAN
  SERVICE
  AI
}

enum UserState {
  PENDING_ACTIVATION
  ACTIVE
  DEACTIVATED
}

enum ThrottleKeyKind {
  USERNAME
  IP
}

enum TokenKind {
  ACTIVATION
  RESET
}

enum SituationLifecycle {
  UNPUBLISHED
  ACTIVE
  ARCHIVED
}

enum PublicationState {
  NEVER_PUBLISHED
  STAGED
  PUBLISHED
  ROLLED_BACK
  RETIRED
}

enum DraftState {
  DISCOVERY
  DRAFTING
  READY_FOR_AI_REVIEW
  AI_REVIEW_QUEUED
  AI_REVIEW_RUNNING
  PROPOSAL_READY
  HUMAN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum CheckoutMode {
  DISCOVERY
  EDITING
  AI_QUEUED
  AI_RUNNING
  HUMAN_REVIEW
  APPROVED
  PUBLISHING
  ARCHIVING
  RESTORING
}

enum CheckoutCustody {
  USER
  AI_JOB
  PUBLISHER
}

enum ArtifactType {
  SITUATION
  GUIDE
  PRACTICE
  LESSON_PLAN
  PREPARATION_PROMPT
  TOOL
  SOURCE
  AUTHOR
  ASSET
  ROUTE
  VALIDATOR
}

enum ContentEncoding {
  UTF8
  BINARY
}

enum ArtifactEdgeType {
  EMBEDS_PRACTICE
  TAUGHT_BY_LESSON
  PREPARES_WITH
  CITES_SOURCE
  LINKS_TO
  CONSUMED_BY_ROUTE
  VALIDATED_BY
}

enum SnapshotKind {
  LEGACY_IMPORT
  STUDIO_PUBLICATION
  EXTERNAL_REPOSITORY_VERSION
  ROLLBACK
}

enum VersionSourceKind {
  LEGACY_IMPORT
  MANUAL_DRAFT
  AI_PROPOSAL
  PUBLICATION
  EXTERNAL_REPOSITORY_VERSION
  ROLLBACK
}

enum ChangeKind {
  ADD
  MODIFY
  DELETE
  NO_CHANGE
}

enum ConversationKind {
  NEW_SITUATION
  FOCUSED_REVISION
}

enum ConversationState {
  OPEN
  WAITING
  READY
  CLOSED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum BriefFieldState {
  CONFIRMED_FACT
  USER_ACCEPTED_ASSUMPTION
  DELIBERATE_UNKNOWN
  UNRESOLVED_BLOCKER
}

enum AiJobState {
  QUEUED
  RUNNING
  WAITING_CAPACITY
  RETRY_SCHEDULED
  CANCELLING
  CANCELLED
  SUCCEEDED
  INCOMPLETE
  FAILED
}

enum WorkflowStepState {
  PENDING
  READY
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ProviderState {
  ENABLED
  PAUSED
  AUTH_FAILED
  CAPACITY_WAIT
  UNHEALTHY
}

enum FailureClass {
  PROVIDER_CAPACITY_EXHAUSTED
  PROVIDER_TRANSIENT
  PROVIDER_AUTH_CONFIG
  MODEL_OUTPUT_INVALID
  APPLICATION_FAILURE
  WORKSPACE_SECURITY_FAILURE
  CANCELLED
}

enum BundleState {
  DRAFT
  PROPOSAL_READY
  HUMAN_REVIEW
  APPROVED
  STALE
  PUBLISHED
}

enum ValidationState {
  QUEUED
  RUNNING
  PASSED
  FAILED
  EXPIRED
}

enum PublicationSagaState {
  REQUESTED
  SNAPSHOT_MATERIALIZED
  SNAPSHOT_VALIDATED
  CANDIDATE_AVAILABLE
  CANDIDATE_VERIFIED
  WORKTREE_READY
  APPLIED
  VALIDATED
  COMMITTED
  PUSHED
  PREVIEW_BUILT
  PREVIEW_VERIFIED
  AWAITING_CONFIRMATION
  OFFICIAL_POINTER_COMMITTED
  RESTORING_PREVIOUS
  CUTOVER
  LIVE_VERIFIED
  RECONCILED
  FAILED_PREVIEW
  AUTO_ROLLED_BACK
  RECONCILIATION_REQUIRED
}

enum ContentSnapshotValidationState {
  MATERIALIZING
  VALIDATED
  REJECTED
}

enum DatabasePublicationOutcome {
  PUBLISHED
  PREVIOUS_VERSION_RESTORED
  FAILED_BEFORE_CONFIRMATION
  RECONCILIATION_REQUIRED
}

enum LeadershipObservationKind {
  CANDIDATE
  OFFICIAL
  RESTORATION
}

enum LeadershipCacheSource {
  DATABASE
  LAST_KNOWN_GOOD
}

enum LeadershipHealthResult {
  HEALTHY
  DEGRADED
  UNHEALTHY
}

model User {
  id                      String                    @id @default(uuid()) @db.Uuid
  username                String                    @unique @db.VarChar(64)
  displayName             String                    @map("display_name") @db.VarChar(120)
  repositoryReviewerId    String?                   @unique @map("repository_reviewer_id") @db.VarChar(100)
  passwordHash            String?                   @map("password_hash") @db.VarChar(512)
  identityType            IdentityType              @default(HUMAN) @map("identity_type")
  state                   UserState                 @default(PENDING_ACTIVATION)
  passwordVersion         Int                       @default(1) @map("password_version")
  lastLoginAt             DateTime?                 @map("last_login_at") @db.Timestamptz(3)
  deactivatedAt           DateTime?                 @map("deactivated_at") @db.Timestamptz(3)
  deactivatedById         String?                   @map("deactivated_by_id") @db.Uuid
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)
  sessions                Session[]
  roleAssignments         UserRoleAssignment[]      @relation("RoleSubject")
  rolesGranted            UserRoleAssignment[]      @relation("RoleGrantor")
  permissionGrants        UserPermissionGrant[]     @relation("PermissionSubject")
  permissionsGranted      UserPermissionGrant[]     @relation("PermissionGrantor")
  activationTokens        ActivationToken[]         @relation("TokenSubject")
  activationTokensMade    ActivationToken[]         @relation("TokenCreator")
  checkouts               SituationCheckout[]       @relation("CheckoutHolder")
  auditEvents             AuditEvent[]              @relation("AuditActor")
  databasePublications    DatabasePublication[]     @relation("DatabasePublicationPublisher")
  publicationConfirms     PublicationConfirmation[]
  candidateAuthorizations CandidateAuthorization[]
  rollbackRequests        RollbackRequest[]         @relation("RollbackRequester")

  @@index([state, username], map: "users_state_username_idx")
  @@map("users")
}

model Role {
  id            String               @id @default(uuid()) @db.Uuid
  code          String               @unique @db.VarChar(50)
  displayName   String               @map("display_name") @db.VarChar(100)
  systemManaged Boolean              @default(true) @map("system_managed")
  version       Int                  @default(1)
  permissions   RolePermission[]
  assignments   UserRoleAssignment[]

  @@map("roles")
}

model Permission {
  id          String                @id @default(uuid()) @db.Uuid
  code        String                @unique @db.VarChar(80)
  description String                @db.VarChar(300)
  roles       RolePermission[]
  grants      UserPermissionGrant[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  userId      String   @map("user_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  grantedById String   @map("granted_by_id") @db.Uuid
  grantedAt   DateTime @default(now()) @map("granted_at") @db.Timestamptz(3)
  user        User     @relation("RoleSubject", fields: [userId], references: [id], onDelete: Restrict)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  grantedBy   User     @relation("RoleGrantor", fields: [grantedById], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserPermissionGrant {
  userId       String     @map("user_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  grantedById  String     @map("granted_by_id") @db.Uuid
  grantedAt    DateTime   @default(now()) @map("granted_at") @db.Timestamptz(3)
  user         User       @relation("PermissionSubject", fields: [userId], references: [id], onDelete: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)
  grantedBy    User       @relation("PermissionGrantor", fields: [grantedById], references: [id], onDelete: Restrict)

  @@id([userId, permissionId])
  @@map("user_permission_grants")
}

model Session {
  id                       String                    @id @default(uuid()) @db.Uuid
  tokenHash                String                    @unique @map("token_hash") @db.Char(64)
  userId                   String                    @map("user_id") @db.Uuid
  passwordVersion          Int                       @map("password_version")
  csrfSecretHash           String                    @map("csrf_secret_hash") @db.Char(64)
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  lastSeenAt               DateTime                  @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  idleExpiresAt            DateTime                  @map("idle_expires_at") @db.Timestamptz(3)
  absoluteExpiresAt        DateTime                  @map("absolute_expires_at") @db.Timestamptz(3)
  reauthenticatedAt        DateTime?                 @map("reauthenticated_at") @db.Timestamptz(3)
  revokedAt                DateTime?                 @map("revoked_at") @db.Timestamptz(3)
  revokedReason            String?                   @map("revoked_reason") @db.VarChar(200)
  ipHash                   String?                   @map("ip_hash") @db.Char(64)
  userAgentClass           String?                   @map("user_agent_class") @db.VarChar(80)
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Restrict)
  publicationConfirmations PublicationConfirmation[]

  @@index([userId, absoluteExpiresAt], map: "sessions_user_expiry_idx")
  @@map("sessions")
}

model LoginThrottle {
  id              String          @id @default(uuid()) @db.Uuid
  keyKind         ThrottleKeyKind @map("key_kind")
  keyHash         String          @map("key_hash") @db.Char(64)
  failureCount    Int             @default(0) @map("failure_count")
  windowStartedAt DateTime        @map("window_started_at") @db.Timestamptz(3)
  blockedUntil    DateTime?       @map("blocked_until") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([keyKind, keyHash])
  @@index([blockedUntil], map: "login_throttles_blocked_until_idx")
  @@map("login_throttles")
}

model ActivationToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.Char(64)
  kind        TokenKind
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(3)
  user        User      @relation("TokenSubject", fields: [userId], references: [id], onDelete: Restrict)
  createdBy   User      @relation("TokenCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([userId, kind, expiresAt], map: "activation_tokens_subject_idx")
  @@map("activation_tokens")
}

model RepositorySnapshot {
  id              String             @id @default(uuid()) @db.Uuid
  commitSha       String             @unique @map("commit_sha") @db.Char(40)
  manifest        Json
  manifestHash    String             @map("manifest_hash") @db.Char(64)
  parserVersion   String             @map("parser_version") @db.VarChar(80)
  importKind      SnapshotKind       @map("import_kind")
  validationState String             @map("validation_state") @db.VarChar(30)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  artifacts       Artifact[]
  edges           ArtifactEdge[]
  versions        SituationVersion[]
  drafts          Draft[]
  bundles         ProposedBundle[]

  @@map("repository_snapshots")
}

model Situation {
  id                   String              @id @default(uuid()) @db.Uuid
  slug                 String              @unique @db.VarChar(120)
  title                String              @db.VarChar(240)
  lifecycle            SituationLifecycle  @default(UNPUBLISHED)
  publicationState     PublicationState    @default(NEVER_PUBLISHED) @map("publication_state")
  currentPublicationId String?             @unique @map("current_publication_id") @db.Uuid
  previousLifecycle    SituationLifecycle? @map("previous_lifecycle")
  archivedAt           DateTime?           @map("archived_at") @db.Timestamptz(3)
  archivedById         String?             @map("archived_by_id") @db.Uuid
  archiveReason        String?             @map("archive_reason") @db.VarChar(500)
  fence                BigInt              @default(0)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  currentPublication   Publication?        @relation("CurrentPublication", fields: [currentPublicationId], references: [id], onDelete: Restrict)
  publications         Publication[]       @relation("SituationPublications")
  artifacts            Artifact[]
  versions             SituationVersion[]
  drafts               Draft[]
  checkouts            SituationCheckout[]
  conversations        Conversation[]
  aiJobs               AiJob[]
  bundles              ProposedBundle[]
  archiveRecords       ArchiveRecord[]
  rollbackRequests     RollbackRequest[]

  @@index([lifecycle, publicationState, title], map: "situations_inventory_idx")
  @@map("situations")
}

model ContentBlob {
  hash              String                    @id @db.Char(64)
  body              String
  encoding          ContentEncoding           @default(UTF8)
  binaryBody        Bytes?                    @map("binary_body")
  byteLength        Int                       @map("byte_length")
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  versionArtifacts  VersionArtifact[]
  draftArtifacts    DraftArtifact[]
  bundleArtifacts   BundleArtifact[]
  snapshotArtifacts ContentSnapshotArtifact[]

  @@map("content_blobs")
}

model Artifact {
  id                   String                    @id @default(uuid()) @db.Uuid
  logicalId            String                    @unique @map("logical_id") @db.VarChar(200)
  type                 ArtifactType
  canonicalPath        String                    @unique @map("canonical_path") @db.VarChar(500)
  primarySituationId   String?                   @map("primary_situation_id") @db.Uuid
  repositorySnapshotId String                    @map("repository_snapshot_id") @db.Uuid
  active               Boolean                   @default(true)
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)
  primarySituation     Situation?                @relation(fields: [primarySituationId], references: [id], onDelete: Restrict)
  repositorySnapshot   RepositorySnapshot        @relation(fields: [repositorySnapshotId], references: [id], onDelete: Restrict)
  outgoingEdges        ArtifactEdge[]            @relation("EdgeSource")
  incomingEdges        ArtifactEdge[]            @relation("EdgeTarget")
  versionArtifacts     VersionArtifact[]
  draftArtifacts       DraftArtifact[]
  checkoutResources    CheckoutResource[]
  bundleArtifacts      BundleArtifact[]
  snapshotArtifacts    ContentSnapshotArtifact[]

  @@index([type, active], map: "artifacts_type_active_idx")
  @@map("artifacts")
}

model ArtifactEdge {
  id         String             @id @default(uuid()) @db.Uuid
  snapshotId String             @map("snapshot_id") @db.Uuid
  sourceId   String             @map("source_id") @db.Uuid
  targetId   String             @map("target_id") @db.Uuid
  edgeType   ArtifactEdgeType   @map("edge_type")
  evidence   String             @db.VarChar(500)
  snapshot   RepositorySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  source     Artifact           @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Restrict)
  target     Artifact           @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Restrict)

  @@unique([snapshotId, sourceId, targetId, edgeType])
  @@index([targetId, edgeType], map: "artifact_edges_target_idx")
  @@map("artifact_edges")
}

model SituationVersion {
  id            String             @id @default(uuid()) @db.Uuid
  situationId   String             @map("situation_id") @db.Uuid
  sourceKind    VersionSourceKind  @map("source_kind")
  snapshotId    String             @map("snapshot_id") @db.Uuid
  manifestHash  String             @map("manifest_hash") @db.Char(64)
  bundleHash    String?            @map("bundle_hash") @db.Char(64)
  actorId       String?            @map("actor_id") @db.Uuid
  aiJobId       String?            @map("ai_job_id") @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  situation     Situation          @relation(fields: [situationId], references: [id], onDelete: Restrict)
  snapshot      RepositorySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  artifacts     VersionArtifact[]
  draftsBasedOn Draft[]
  publications  Publication[]

  @@index([situationId, createdAt], map: "situation_versions_timeline_idx")
  @@map("situation_versions")
}

model VersionArtifact {
  versionId   String           @map("version_id") @db.Uuid
  artifactId  String           @map("artifact_id") @db.Uuid
  path        String           @db.VarChar(500)
  type        ArtifactType
  contentHash String           @map("content_hash") @db.Char(64)
  changeKind  ChangeKind       @map("change_kind")
  version     SituationVersion @relation(fields: [versionId], references: [id], onDelete: Restrict)
  artifact    Artifact         @relation(fields: [artifactId], references: [id], onDelete: Restrict)
  content     ContentBlob      @relation(fields: [contentHash], references: [hash], onDelete: Restrict)

  @@id([versionId, artifactId])
  @@map("version_artifacts")
}

model Draft {
  id              String              @id @default(uuid()) @db.Uuid
  situationId     String              @map("situation_id") @db.Uuid
  baseVersionId   String?             @map("base_version_id") @db.Uuid
  baseSnapshotId  String              @map("base_snapshot_id") @db.Uuid
  currentRevision Int                 @default(0) @map("current_revision")
  state           DraftState          @default(DRAFTING)
  staleReason     String?             @map("stale_reason") @db.VarChar(500)
  active          Boolean             @default(true)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  situation       Situation           @relation(fields: [situationId], references: [id], onDelete: Restrict)
  baseVersion     SituationVersion?   @relation(fields: [baseVersionId], references: [id], onDelete: Restrict)
  baseSnapshot    RepositorySnapshot  @relation(fields: [baseSnapshotId], references: [id], onDelete: Restrict)
  revisions       DraftRevision[]
  checkouts       SituationCheckout[]
  conversations   Conversation[]
  aiJobs          AiJob[]
  bundles         ProposedBundle[]

  @@index([situationId, active], map: "drafts_situation_active_idx")
  @@map("drafts")
}

model DraftRevision {
  id               String          @id @default(uuid()) @db.Uuid
  draftId          String          @map("draft_id") @db.Uuid
  revision         Int
  parentRevisionId String?         @map("parent_revision_id") @db.Uuid
  manifestHash     String          @map("manifest_hash") @db.Char(64)
  actorId          String          @map("actor_id") @db.Uuid
  clientMutationId String?         @map("client_mutation_id") @db.Uuid
  namedCheckpoint  String?         @map("named_checkpoint") @db.VarChar(160)
  materialChange   Boolean         @default(true) @map("material_change")
  semanticChange   Boolean         @default(true) @map("semantic_change")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  draft            Draft           @relation(fields: [draftId], references: [id], onDelete: Restrict)
  parentRevision   DraftRevision?  @relation("RevisionParent", fields: [parentRevisionId], references: [id], onDelete: Restrict)
  childRevisions   DraftRevision[] @relation("RevisionParent")
  artifacts        DraftArtifact[]

  @@unique([draftId, revision])
  @@unique([draftId, clientMutationId])
  @@map("draft_revisions")
}

model DraftArtifact {
  revisionId  String        @map("revision_id") @db.Uuid
  artifactId  String        @map("artifact_id") @db.Uuid
  path        String        @db.VarChar(500)
  type        ArtifactType
  contentHash String        @map("content_hash") @db.Char(64)
  changeKind  ChangeKind    @map("change_kind")
  revision    DraftRevision @relation(fields: [revisionId], references: [id], onDelete: Restrict)
  artifact    Artifact      @relation(fields: [artifactId], references: [id], onDelete: Restrict)
  content     ContentBlob   @relation(fields: [contentHash], references: [hash], onDelete: Restrict)

  @@id([revisionId, artifactId])
  @@map("draft_artifacts")
}

model SituationCheckout {
  id               String             @id @default(uuid()) @db.Uuid
  situationId      String             @map("situation_id") @db.Uuid
  holderUserId     String?            @map("holder_user_id") @db.Uuid
  mode             CheckoutMode
  custody          CheckoutCustody    @default(USER)
  custodyReference String?            @map("custody_reference") @db.Uuid
  draftId          String?            @map("draft_id") @db.Uuid
  fencingToken     BigInt             @map("fencing_token")
  acquiredAt       DateTime           @default(now()) @map("acquired_at") @db.Timestamptz(3)
  renewedAt        DateTime           @default(now()) @map("renewed_at") @db.Timestamptz(3)
  expiresAt        DateTime           @map("expires_at") @db.Timestamptz(3)
  releasedAt       DateTime?          @map("released_at") @db.Timestamptz(3)
  releaseReason    String?            @map("release_reason") @db.VarChar(500)
  transferReason   String?            @map("transfer_reason") @db.VarChar(500)
  situation        Situation          @relation(fields: [situationId], references: [id], onDelete: Restrict)
  holder           User?              @relation("CheckoutHolder", fields: [holderUserId], references: [id], onDelete: Restrict)
  draft            Draft?             @relation(fields: [draftId], references: [id], onDelete: Restrict)
  resources        CheckoutResource[]

  @@index([situationId, releasedAt], map: "checkouts_situation_active_idx")
  @@index([holderUserId, releasedAt], map: "checkouts_holder_active_idx")
  @@map("situation_checkouts")
}

model CheckoutResource {
  id          String            @id @default(uuid()) @db.Uuid
  checkoutId  String            @map("checkout_id") @db.Uuid
  artifactId  String?           @map("artifact_id") @db.Uuid
  situationId String?           @map("situation_id") @db.Uuid
  resourceKey String            @map("resource_key") @db.VarChar(260)
  purpose     String            @db.VarChar(120)
  acquiredAt  DateTime          @default(now()) @map("acquired_at") @db.Timestamptz(3)
  releasedAt  DateTime?         @map("released_at") @db.Timestamptz(3)
  checkout    SituationCheckout @relation(fields: [checkoutId], references: [id], onDelete: Restrict)
  artifact    Artifact?         @relation(fields: [artifactId], references: [id], onDelete: Restrict)

  @@index([resourceKey, releasedAt], map: "checkout_resources_active_idx")
  @@map("checkout_resources")
}

model Conversation {
  id             String                     @id @default(uuid()) @db.Uuid
  situationId    String                     @map("situation_id") @db.Uuid
  draftId        String                     @map("draft_id") @db.Uuid
  kind           ConversationKind
  state          ConversationState          @default(OPEN)
  ownerId        String                     @map("owner_id") @db.Uuid
  currentBriefId String?                    @unique @map("current_brief_id") @db.Uuid
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)
  situation      Situation                  @relation(fields: [situationId], references: [id], onDelete: Restrict)
  draft          Draft                      @relation(fields: [draftId], references: [id], onDelete: Restrict)
  currentBrief   SharedUnderstandingBrief?  @relation("CurrentBrief", fields: [currentBriefId], references: [id], onDelete: Restrict)
  briefs         SharedUnderstandingBrief[] @relation("ConversationBriefs")
  messages       ConversationMessage[]

  @@map("conversations")
}

model ConversationMessage {
  id                   String       @id @default(uuid()) @db.Uuid
  conversationId       String       @map("conversation_id") @db.Uuid
  sequence             Int
  role                 MessageRole
  body                 String
