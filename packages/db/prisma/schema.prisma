  databasePublicationResults    DatabasePublication[]          @relation("DatabasePublicationResult")
  confirmations                 PublicationConfirmation[]
  candidateAuthorizations       CandidateAuthorization[]
  observations                  LeadershipObservationReceipt[]

  @@index([parentSnapshotId], map: "content_snapshots_parent_idx")
  @@index([validationState, createdAt], map: "content_snapshots_validation_idx")
  @@map("content_snapshots")
}

model ContentSnapshotArtifact {
  snapshotId    String                @map("snapshot_id") @db.Uuid
  artifactId    String                @map("artifact_id") @db.Uuid
  logicalId     String                @map("logical_id") @db.VarChar(200)
  canonicalPath String                @map("canonical_path") @db.VarChar(500)
  artifactType  ArtifactType          @map("artifact_type")
  contentHash   String                @map("content_hash") @db.Char(64)
  byteLength    Int                   @map("byte_length")
  snapshot      ContentSnapshot       @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  artifact      Artifact              @relation(fields: [artifactId], references: [id], onDelete: Restrict)
  content       ContentBlob           @relation(fields: [contentHash], references: [hash], onDelete: Restrict)
  outgoingEdges ContentSnapshotEdge[] @relation("SnapshotEdgeSource")
  incomingEdges ContentSnapshotEdge[] @relation("SnapshotEdgeTarget")

  @@id([snapshotId, artifactId])
  @@unique([snapshotId, logicalId], map: "content_snapshot_artifacts_logical_id_key")
  @@unique([snapshotId, canonicalPath], map: "content_snapshot_artifacts_path_key")
  @@index([snapshotId, artifactType], map: "content_snapshot_artifacts_type_idx")
  @@map("content_snapshot_artifacts")
}

model ContentSnapshotEdge {
  id               String                  @id @default(uuid()) @db.Uuid
  snapshotId       String                  @map("snapshot_id") @db.Uuid
  sourceArtifactId String                  @map("source_artifact_id") @db.Uuid
  targetArtifactId String                  @map("target_artifact_id") @db.Uuid
  edgeType         ArtifactEdgeType        @map("edge_type")
  evidence         String                  @db.VarChar(500)
  snapshot         ContentSnapshot         @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  source           ContentSnapshotArtifact @relation("SnapshotEdgeSource", fields: [snapshotId, sourceArtifactId], references: [snapshotId, artifactId], onDelete: Restrict)
  target           ContentSnapshotArtifact @relation("SnapshotEdgeTarget", fields: [snapshotId, targetArtifactId], references: [snapshotId, artifactId], onDelete: Restrict)

  @@unique([snapshotId, sourceArtifactId, targetArtifactId, edgeType], map: "content_snapshot_edges_identity_key")
  @@index([snapshotId, targetArtifactId, edgeType], map: "content_snapshot_edges_target_idx")
  @@map("content_snapshot_edges")
}

model PublicationTarget {
  id                            String                         @id @default(uuid()) @db.Uuid
  code                          String                         @unique @db.VarChar(50)
  officialSnapshotId            String?                        @map("official_snapshot_id") @db.Uuid
  candidateSnapshotId           String?                        @map("candidate_snapshot_id") @db.Uuid
  candidatePublicationRequestId String?                        @unique @map("candidate_publication_request_id") @db.Uuid
  candidateRollbackRequestId    String?                        @unique @map("candidate_rollback_request_id") @db.Uuid
  currentDatabasePublicationId  String?                        @map("current_database_publication_id") @db.Uuid
  generation                    BigInt                         @default(0)
  bootstrappedAt                DateTime?                      @map("bootstrapped_at") @db.Timestamptz(3)
  createdAt                     DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                     DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(3)
  officialSnapshot              ContentSnapshot?               @relation("TargetOfficialSnapshot", fields: [officialSnapshotId], references: [id], onDelete: Restrict)
  candidateSnapshot             ContentSnapshot?               @relation("TargetCandidateSnapshot", fields: [candidateSnapshotId], references: [id], onDelete: Restrict)
  candidatePublicationRequest   PublicationRequest?            @relation("TargetCandidatePublicationRequest", fields: [candidatePublicationRequestId], references: [id], onDelete: Restrict)
  candidateRollbackRequest      RollbackRequest?               @relation("TargetCandidateRollbackRequest", fields: [candidateRollbackRequestId], references: [id], onDelete: Restrict)
  currentDatabasePublication    DatabasePublication?           @relation("TargetCurrentDatabasePublication", fields: [currentDatabasePublicationId], references: [id], onDelete: Restrict)
  publicationRequests           PublicationRequest[]           @relation("PublicationRequestTarget")
  rollbackRequests              RollbackRequest[]              @relation("RollbackRequestTarget")
  databasePublications          DatabasePublication[]          @relation("DatabasePublicationTarget")
  events                        PublicationEvent[]
  confirmations                 PublicationConfirmation[]
  candidateAuthorizations       CandidateAuthorization[]
  observations                  LeadershipObservationReceipt[]

  @@map("publication_targets")
}

model DatabasePublication {
  id                          String                         @id @default(uuid()) @db.Uuid
  publicationUuid             String                         @unique @map("publication_uuid") @db.Uuid
  publicationRequestId        String?                        @unique @map("publication_request_id") @db.Uuid
  rollbackRequestId           String?                        @unique @map("rollback_request_id") @db.Uuid
  targetId                    String                         @map("target_id") @db.Uuid
  bundleId                    String?                        @map("bundle_id") @db.Uuid
  approvalId                  String?                        @map("approval_id") @db.Uuid
  candidateSnapshotId         String?                        @map("candidate_snapshot_id") @db.Uuid
  previousOfficialSnapshotId  String                         @map("previous_official_snapshot_id") @db.Uuid
  resultingOfficialSnapshotId String?                        @map("resulting_official_snapshot_id") @db.Uuid
  publisherIdentityId         String                         @map("publisher_identity_id") @db.Uuid
  confirmationId              String?                        @unique @map("confirmation_id") @db.Uuid
  healthReceiptId             String?                        @unique @map("health_receipt_id") @db.Uuid
  state                       PublicationSagaState           @default(REQUESTED)
  terminalOutcome             DatabasePublicationOutcome?    @map("terminal_outcome")
  createdAt                   DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                   DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(3)
  publicationRequest          PublicationRequest?            @relation(fields: [publicationRequestId], references: [id], onDelete: Restrict)
  rollbackRequest             RollbackRequest?               @relation(fields: [rollbackRequestId], references: [id], onDelete: Restrict)
  target                      PublicationTarget              @relation("DatabasePublicationTarget", fields: [targetId], references: [id], onDelete: Restrict)
  currentForTarget            PublicationTarget[]            @relation("TargetCurrentDatabasePublication")
  bundle                      ProposedBundle?                @relation(fields: [bundleId], references: [id], onDelete: Restrict)
  approval                    Approval?                      @relation(fields: [approvalId], references: [id], onDelete: Restrict)
  candidateSnapshot           ContentSnapshot?               @relation("DatabasePublicationCandidate", fields: [candidateSnapshotId], references: [id], onDelete: Restrict)
  previousOfficialSnapshot    ContentSnapshot                @relation("DatabasePublicationPrevious", fields: [previousOfficialSnapshotId], references: [id], onDelete: Restrict)
  resultingOfficialSnapshot   ContentSnapshot?               @relation("DatabasePublicationResult", fields: [resultingOfficialSnapshotId], references: [id], onDelete: Restrict)
  publisherIdentity           User                           @relation("DatabasePublicationPublisher", fields: [publisherIdentityId], references: [id], onDelete: Restrict)
  confirmation                PublicationConfirmation?       @relation(fields: [confirmationId], references: [id], onDelete: Restrict)
  healthReceipt               LeadershipObservationReceipt?  @relation("PublicationHealthReceipt", fields: [healthReceiptId], references: [id], onDelete: Restrict)
  observations                LeadershipObservationReceipt[] @relation("PublicationObservations")

  @@index([targetId, state], map: "database_publications_target_state_idx")
  @@index([createdAt], map: "database_publications_created_idx")
  @@map("database_publications")
}

model PublicationEvent {
  id                   String              @id @default(uuid()) @db.Uuid
  publicationRequestId String?             @map("publication_request_id") @db.Uuid
  rollbackRequestId    String?             @map("rollback_request_id") @db.Uuid
  targetId             String              @map("target_id") @db.Uuid
  sequence             BigInt
  eventKey             String              @map("event_key") @db.VarChar(120)
  eventType            String              @map("event_type") @db.VarChar(80)
  payload              Json
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  publicationRequest   PublicationRequest? @relation(fields: [publicationRequestId], references: [id], onDelete: Restrict)
  rollbackRequest      RollbackRequest?    @relation(fields: [rollbackRequestId], references: [id], onDelete: Restrict)
  target               PublicationTarget   @relation(fields: [targetId], references: [id], onDelete: Restrict)

  @@unique([publicationRequestId, sequence], map: "publication_events_request_sequence_key")
  @@unique([publicationRequestId, eventKey], map: "publication_events_request_event_key")
  @@unique([rollbackRequestId, sequence], map: "publication_events_rollback_sequence_key")
  @@unique([rollbackRequestId, eventKey], map: "publication_events_rollback_event_key")
  @@index([targetId, createdAt], map: "publication_events_target_created_idx")
  @@map("publication_events")
}

model PublicationConfirmation {
  id                     String               @id @default(uuid()) @db.Uuid
  publicationRequestId   String?              @map("publication_request_id") @db.Uuid
  rollbackRequestId      String?              @map("rollback_request_id") @db.Uuid
  targetId               String               @map("target_id") @db.Uuid
  snapshotId             String               @map("snapshot_id") @db.Uuid
  snapshotHash           String               @map("snapshot_hash") @db.Char(64)
  approvalId             String?              @map("approval_id") @db.Uuid
  confirmedById          String               @map("confirmed_by_id") @db.Uuid
  sessionId              String               @map("session_id") @db.Uuid
  validationPolicyHash   String               @map("validation_policy_hash") @db.Char(64)
  targetGeneration       BigInt               @map("target_generation")
  recentAuthenticationAt DateTime             @map("recent_authentication_at") @db.Timestamptz(3)
  confirmedAt            DateTime             @default(now()) @map("confirmed_at") @db.Timestamptz(3)
  publicationRequest     PublicationRequest?  @relation(fields: [publicationRequestId], references: [id], onDelete: Restrict)
  rollbackRequest        RollbackRequest?     @relation(fields: [rollbackRequestId], references: [id], onDelete: Restrict)
  target                 PublicationTarget    @relation(fields: [targetId], references: [id], onDelete: Restrict)
  snapshot               ContentSnapshot      @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  approval               Approval?            @relation(fields: [approvalId], references: [id], onDelete: Restrict)
  confirmedBy            User                 @relation(fields: [confirmedById], references: [id], onDelete: Restrict)
  session                Session              @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  databasePublication    DatabasePublication?

  @@unique([publicationRequestId], map: "publication_confirmations_publication_request_key")
  @@unique([rollbackRequestId], map: "publication_confirmations_rollback_request_key")
  @@index([targetId, confirmedAt], map: "publication_confirmations_target_idx")
  @@map("publication_confirmations")
}

model CandidateAuthorization {
  id                   String              @id @default(uuid()) @db.Uuid
  publicationRequestId String?             @map("publication_request_id") @db.Uuid
  rollbackRequestId    String?             @map("rollback_request_id") @db.Uuid
  targetId             String              @map("target_id") @db.Uuid
  snapshotId           String              @map("snapshot_id") @db.Uuid
  snapshotHash         String              @map("snapshot_hash") @db.Char(64)
  reviewerId           String              @map("reviewer_id") @db.Uuid
  exchangeTokenHash    String              @unique @map("exchange_token_hash") @db.Char(64)
  handoffId            String?             @unique @map("handoff_id") @db.Uuid
  handoffVerifierHash  String?             @map("handoff_verifier_hash") @db.Char(64)
  cookieTokenHash      String?             @unique @map("cookie_token_hash") @db.Char(64)
  audience             String              @db.VarChar(120)
  expiresAt            DateTime            @map("expires_at") @db.Timestamptz(3)
  exchangedAt          DateTime?           @map("exchanged_at") @db.Timestamptz(3)
  revokedAt            DateTime?           @map("revoked_at") @db.Timestamptz(3)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  publicationRequest   PublicationRequest? @relation(fields: [publicationRequestId], references: [id], onDelete: Restrict)
  rollbackRequest      RollbackRequest?    @relation(fields: [rollbackRequestId], references: [id], onDelete: Restrict)
  target               PublicationTarget   @relation(fields: [targetId], references: [id], onDelete: Restrict)
  snapshot             ContentSnapshot     @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  reviewer             User                @relation(fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([targetId, snapshotId, expiresAt], map: "candidate_authorizations_lookup_idx")
  @@index([reviewerId, expiresAt], map: "candidate_authorizations_reviewer_idx")
  @@map("candidate_authorizations")
}

model LeadershipObservationReceipt {
  id                         String                    @id @default(uuid()) @db.Uuid
  targetId                   String                    @map("target_id") @db.Uuid
  databasePublicationId      String?                   @map("database_publication_id") @db.Uuid
  snapshotId                 String                    @map("snapshot_id") @db.Uuid
  snapshotHash               String                    @map("snapshot_hash") @db.Char(64)
  observationKind            LeadershipObservationKind @map("observation_kind")
  cacheSource                LeadershipCacheSource     @map("cache_source")
  healthResult               LeadershipHealthResult    @map("health_result")
  applicationReleaseIdentity String                    @map("application_release_identity") @db.VarChar(200)
  routeProbeHash             String                    @map("route_probe_hash") @db.Char(64)
  attestationKeyId           String                    @map("attestation_key_id") @db.VarChar(100)
  receiptDigest              String                    @unique @map("receipt_digest") @db.Char(64)
  observedAt                 DateTime                  @map("observed_at") @db.Timestamptz(3)
  createdAt                  DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  target                     PublicationTarget         @relation(fields: [targetId], references: [id], onDelete: Restrict)
  databasePublication        DatabasePublication?      @relation("PublicationObservations", fields: [databasePublicationId], references: [id], onDelete: Restrict)
  snapshot                   ContentSnapshot           @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  healthForPublication       DatabasePublication?      @relation("PublicationHealthReceipt")

  @@index([targetId, snapshotId, observedAt], map: "leadership_observations_snapshot_idx")
  @@index([databasePublicationId, observationKind, healthResult], map: "leadership_observations_publication_idx")
  @@map("leadership_observation_receipts")
}

model ArchiveRecord {
  id                String             @id @default(uuid()) @db.Uuid
  situationId       String             @map("situation_id") @db.Uuid
  action            String             @db.VarChar(20)
  reason            String             @db.VarChar(500)
  actorId           String             @map("actor_id") @db.Uuid
  previousLifecycle SituationLifecycle @map("previous_lifecycle")
  resultLifecycle   SituationLifecycle @map("result_lifecycle")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  situation         Situation          @relation(fields: [situationId], references: [id], onDelete: Restrict)

  @@map("archive_records")
}

model AuditEvent {
  id                 String       @id @default(uuid()) @db.Uuid
  actorType          IdentityType @map("actor_type")
  actorId            String?      @map("actor_id") @db.Uuid
  permissionSnapshot Json?        @map("permission_snapshot")
  action             String       @db.VarChar(120)
  targetType         String       @map("target_type") @db.VarChar(60)
  targetId           String?      @map("target_id") @db.VarChar(120)
  targetVersion      String?      @map("target_version") @db.VarChar(120)
  requestId          String?      @map("request_id") @db.Uuid
  correlationId      String       @map("correlation_id") @db.Uuid
  ipHash             String?      @map("ip_hash") @db.Char(64)
  userAgentClass     String?      @map("user_agent_class") @db.VarChar(80)
  beforeMetadata     Json?        @map("before_metadata")
  afterMetadata      Json?        @map("after_metadata")
  outcome            String       @db.VarChar(30)
  reason             String?      @db.VarChar(500)
