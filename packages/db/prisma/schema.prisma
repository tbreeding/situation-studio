  @@index([targetType, targetId, createdAt], map: "audit_events_target_idx")
  @@index([createdAt], map: "audit_events_created_idx")
  @@map("audit_events")
}

model IdempotencyKey {
  id          String   @id @default(uuid()) @db.Uuid
  actorId     String   @map("actor_id") @db.Uuid
  route       String   @db.VarChar(160)
  key         String   @db.VarChar(120)
  requestHash String   @map("request_hash") @db.Char(64)
  responseRef String?  @map("response_ref") @db.VarChar(160)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([actorId, route, key])
  @@index([expiresAt], map: "idempotency_keys_expiry_idx")
  @@map("idempotency_keys")
}

model SystemIncident {
  id           String    @id @default(uuid()) @db.Uuid
  severity     String    @db.VarChar(20)
  type         String    @db.VarChar(80)
  state        String    @db.VarChar(30)
  evidence     Json?
  detectedAt   DateTime  @default(now()) @map("detected_at") @db.Timestamptz(3)
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz(3)
  resolvedById String?   @map("resolved_by_id") @db.Uuid

  @@index([state, severity, detectedAt], map: "system_incidents_open_idx")
  @@map("system_incidents")
}
