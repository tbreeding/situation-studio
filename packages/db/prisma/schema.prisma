model ProposedBundle {
  id                  String                    @id @default(uuid()) @db.Uuid
  situationId         String                    @map("situation_id") @db.Uuid
  parentBundleId      String?                   @map("parent_bundle_id") @db.Uuid
  revision            Int
  snapshotId          String                    @map("snapshot_id") @db.Uuid
  draftId             String                    @map("draft_id") @db.Uuid
  briefId             String?                   @map("brief_id") @db.Uuid
  aiJobId             String?                   @map("ai_job_id") @db.Uuid
  baseCommit          String                    @map("base_commit") @db.Char(40)
  baseManifestHash    String                    @map("base_manifest_hash") @db.Char(64)
  briefHash           String?                   @map("brief_hash") @db.Char(64)
  graphHash           String                    @map("graph_hash") @db.Char(64)
  canonicalHash       String                    @unique @map("canonical_hash") @db.Char(64)
  manifest            Json
